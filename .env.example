# Mercado Pago — https://www.mercadopago.com.co/developers/panel/credentials
# Producción: Access Token de producción. Pruebas: token que empieza por TEST-
MERCADOPAGO_ACCESS_TOKEN=
# Public key para SDK de tarjeta (frontend)
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=
# Moneda del ítem en la preferencia: USD (igual que los planes) o COP
MERCADOPAGO_CURRENCY=USD
# Si MERCADOPAGO_CURRENCY=COP, convierte amountUsd × este tipo (ej. 4200)
# MERCADOPAGO_USD_TO_COP=4200
# Para Brick/cardForm en frontend (debe coincidir con backend)
NEXT_PUBLIC_MERCADOPAGO_CURRENCY=USD
# Si NEXT_PUBLIC_MERCADOPAGO_CURRENCY=COP usa el mismo rate del backend
# NEXT_PUBLIC_MERCADOPAGO_USD_TO_COP=4200

# PayPal — https://developer.paypal.com/dashboard/applications
PAYPAL_CLIENT_ID=...
PAYPAL_CLIENT_SECRET=...
# sandbox | live
PAYPAL_MODE=sandbox
NEXT_PUBLIC_PAYPAL_CLIENT_ID=...

# Comisión que cobra PayPal (cross-border). Default: 5.4% + USD 0.30
# El cliente paga el total con comisión incluida para que Dayana reciba el neto.
# PAYPAL_FEE_PERCENT=0.054
# PAYPAL_FEE_FIXED=0.30

# Comisión que cobra Mercado Pago Colombia (Checkout Pro inmediato).
# Default ~4.75% (3.99% + IVA 19%). Sin componente fijo.
# MERCADOPAGO_FEE_PERCENT=0.0475
# MERCADOPAGO_FEE_FIXED=0

# URL pública del sitio (back_urls de Mercado Pago y retornos PayPal)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
